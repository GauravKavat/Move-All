generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum TenantTier {
  Starter
  Pro
  Enterprise
}

enum TenantHealth {
  Healthy
  AtRisk   @map("At-Risk")
  Limited
}

enum OrderStatus {
  Pending
  Confirmed
  Shipped
  InTransit     @map("In Transit")
  Delivered
  Failed
  Returned
}

enum ShipmentStatus {
  Pending
  InTransit       @map("In Transit")
  OutForDelivery  @map("Out for Delivery")
  Delivered
  Failed
  RTO
}

enum ExceptionStatus {
  Open
  InProgress  @map("In Progress")
  Resolved
}

enum RTOStatus {
  Initiated
  InTransit  @map("In Transit")
  Received
  Refunded
}

enum PickupStatus {
  Pending
  Scheduled
  InTransit  @map("In Transit")
  Completed
  Cancelled
}

enum VehicleType {
  TwoWheeler   @map("2-wheeler")
  FourWheeler  @map("4-wheeler")
  SUV
  Truck
}

enum VendorName {
  DHL
  DTDC
  FedEx
  Bluedart
  Local
}

model Tenant {
  id              String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String       @db.VarChar(255)
  tier            TenantTier   @default(Starter)
  health          TenantHealth @default(Healthy)
  monthlyGmv      Decimal      @default(0.00) @db.Decimal(15, 2) @map("monthly_gmv")
  activeShipments Int          @default(0) @map("active_shipments")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz()

  orders         Order[]
  shipments      Shipment[]
  exceptions     Exception[]
  pickupRequests PickupRequest[]

  @@map("tenants")
}

model Order {
  id           String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId     String      @db.Uuid @map("tenant_id")
  customerName String      @db.VarChar(255) @map("customer_name")
  phone        String      @db.VarChar(50)
  address      String
  pincode      String      @db.VarChar(20)
  status       OrderStatus @default(Pending)
  cost         Decimal     @db.Decimal(12, 2)
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipments      Shipment[]
  pickupRequests PickupRequest[]

  @@map("orders")
}

model Shipment {
  awb            String         @id @db.VarChar(100)
  tenantId       String         @db.Uuid @map("tenant_id")
  orderId        String?        @db.Uuid @map("order_id")
  customerName   String         @db.VarChar(255) @map("customer_name")
  courierPartner String         @db.VarChar(100) @map("courier_partner")
  status         ShipmentStatus @default(Pending)
  eta            DateTime       @db.Timestamptz()
  cost           Decimal        @db.Decimal(12, 2)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz()

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order      Order?      @relation(fields: [orderId], references: [id], onDelete: SetNull)
  exceptions Exception[]

  @@map("shipments")
}

model Exception {
  id              String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId        String          @db.Uuid @map("tenant_id")
  shipmentAwb     String          @db.VarChar(100) @map("shipment_awb")
  reason          String
  lastAttempt     DateTime        @default(now()) @map("last_attempt") @db.Timestamptz()
  status          ExceptionStatus @default(Open)
  overrideEnabled Boolean         @default(false) @map("override_enabled")
  etaDeltaHours   Int             @default(0) @map("eta_delta_hours")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  shipment Shipment @relation(fields: [shipmentAwb], references: [awb], onDelete: Cascade)

  @@map("exceptions")
}

model PickupRequest {
  id              String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  tenantId        String       @db.Uuid @map("tenant_id")
  orderId         String       @db.Uuid @map("order_id")
  customerName    String       @db.VarChar(255) @map("customer_name")
  phone           String       @db.VarChar(50)
  deliveryAddress String       @map("delivery_address")
  billingAddress  String       @map("billing_address")
  weight          Decimal      @db.Decimal(8, 3)
  lengthCm        Decimal      @db.Decimal(6, 2) @map("length_cm")
  widthCm         Decimal      @db.Decimal(6, 2) @map("width_cm")
  heightCm        Decimal      @db.Decimal(6, 2) @map("height_cm")
  boxesCount      Int          @default(1) @map("boxes_count")
  preferredVendor VendorName   @default(Local) @map("preferred_vendor")
  vehicleAlloc    VehicleType  @default(TwoWheeler) @map("vehicle_allocation")
  requestedTime   DateTime     @map("requested_time") @db.Timestamptz()
  scheduledTime   DateTime?    @map("scheduled_time") @db.Timestamptz()
  status          PickupStatus @default(Pending)
  vehicleNumber   String?      @db.VarChar(50) @map("vehicle_number")
  driverName      String?      @db.VarChar(255) @map("driver_name")
  driverPhone     String?      @db.VarChar(50) @map("driver_phone")
  estimatedPickup DateTime?    @map("estimated_pickup") @db.Timestamptz()
  actualPickup    DateTime?    @map("actual_pickup") @db.Timestamptz()
  notes           String?
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz()

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("pickup_requests")
}

model AuditLog {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  actor     String   @db.VarChar(255)
  action    String   @db.VarChar(255)
  target    String   @db.VarChar(255)
  timestamp DateTime @default(now()) @db.Timestamptz()
  severity  String   @db.VarChar(50)

  @@map("audit_logs")
}
